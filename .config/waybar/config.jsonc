{
	"include": [
		/* modules-left */
		"./modules/custom/power-menu.jsonc",
		"./modules/temperature.jsonc",
		"./modules/cpu.jsonc",
		"./modules/memory.jsonc",
		"./modules/systemd-failed-units.jsonc",
		/* modules-center */
		"./modules/clock.jsonc",
		/* modules-right */
		"./modules/tray.jsonc",
		"./modules/bluetooth.jsonc",
		"./modules/network.jsonc",
		"./modules/mpris.jsonc",
		"./modules/pulseaudio.jsonc",
		"./modules/backlight.jsonc",
		"./modules/battery.jsonc"
		/* Extra */
	],
	"modules-left": [
		"group/power-menu",
		"temperature",
		"cpu",
		"memory",
		"systemd-failed-units"
	],
	"modules-center": [
		"clock"
	],
	"modules-right": [
		"tray",
		"bluetooth",
		"network",
		"mpris",
		"group/pulseaudio",
		"backlight",
		"battery"
	],
	/* Options */
	"layer": "bottom",
	"height": 0,
	"width": 0,
	"margin": 0,
	"spacing": 10,
	"reload_style_on_change": true
}
